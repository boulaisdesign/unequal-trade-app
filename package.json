{
  "name": "unequal-trade",
  "version": "1.0.0",
  "description": "Unequal Trade — AI Trading Agent Dashboard",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "web": "node web/server.js"
  },
  "build": {
    "appId": "com.unequaltrade.dashboard",
    "productName": "Unequal Trade",
    "mac": {
      "category": "public.app-category.finance",
      "icon": "src/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Unequal Trade",
      "background": null
    }
  },
  "dependencies": {
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
